{
	"name": "Slick Lavender",
	"type": "dark",
	"tokenColors": [
		{
			"name": "Comment",
			"scope": [
				"comment"
			],
			"settings": {
				"foreground": "#8070a0",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Constant",
			"scope": [
				"constant"
			],
			"settings": {
				"foreground": "#ffb452"
			}
		},
		{
			"name": "Keyword",
			"scope": [
				"keyword"
			],
			"settings": {
				"foreground": "#b899e0"
			}
		},
		{
			"name": "Entity",
			"scope": [
				"entity"
			],
			"settings": {
				"foreground": "#c9a8f0"
			}
		},
		{
			"name": "Storage",
			"scope": [
				"storage"
			],
			"settings": {
				"foreground": "#c0a0e8",
				"fontStyle": "bold"
			}
		},
		{
			"name": "String",
			"scope": [
				"string"
			],
			"settings": {
				"foreground": "#e8ffe5",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Support",
			"scope": [
				"support"
			],
			"settings": {
				"foreground": "#d4b8f8",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Variable",
			"scope": [
				"variable"
			],
			"settings": {
				"foreground": "#88ff88",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Invalid",
			"scope": [
				"invalid"
			],
			"settings": {
				"foreground": "#ffffffff",
				"background": "#7755aa"
			}
		},
		{
			"name": "Embedded Source",
			"scope": [
				"text source"
			],
			"settings": {
				"background": "#b0b3ba14"
			}
		},
		{
			"name": "Entity inherited-class",
			"scope": [
				"entity.other.inherited-class"
			],
			"settings": {
				"foreground": "#aa5507ff",
				"fontStyle": "underline"
			}
		},
		{
			"name": "String embedded-source",
			"scope": [
				"string.quoted source"
			],
			"settings": {
				"foreground": "#9df39fff"
			}
		},
		{
			"name": "String constant",
			"scope": [
				"string constant"
			],
			"settings": {
				"foreground": "#ffe862ff"
			}
		},
		{
			"name": "String.regexp",
			"scope": [
				"string.regexp"
			],
			"settings": {
				"foreground": "#ffb454ff"
			}
		},
		{
			"name": "Support.function",
			"scope": [
				"support.function"
			],
			"settings": {
				"foreground": "#ffb454ff"
			}
		},
		{
			"name": "Support.constant",
			"scope": [
				"support.constant"
			],
			"settings": {
				"foreground": "#c0a8ebff"
			}
		},
		{
			"name": "Doctype/XML Processing",
			"scope": [
				"declaration.sgml.html declaration.doctype",
				"declaration.sgml.html declaration.doctype entity",
				"declaration.sgml.html declaration.doctype string",
				"declaration.xml-processing",
				"declaration.xml-processing entity",
				"declaration.xml-processing string"
			],
			"settings": {
				"foreground": "#73817dff"
			}
		},
		{
			"name": "Tags",
			"scope": [
				"declaration.tag",
				"meta.tag"
			],
			"settings": {
				"foreground": "#ff8250",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Tag Entities",
			"scope": [
				"declaration.tag.inline",
				"declaration.tag.inline entity",
				"source entity.name.tag",
				"source entity.other.attribute-name",
				"meta.tag.inline",
				"meta.tag.inline entity",
				"entity.other.bracket"
			],
			"settings": {
				"foreground": "#9977cc",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Tag Attributes",
			"scope": [
				"declaration.tag attribute-name",
				"meta.tag entity.other.attribute-name"
			],
			"settings": {
				"foreground": "#ebe71f",
				"fontStyle": "bold"
			}
		},
		{
			"name": "CSS Class",
			"scope": [
				"meta.selector.css entity.other.attribute-name.class"
			],
			"settings": {
				"foreground": "#d4b8f8"
			}
		},
		{
			"name": "CSS Property Name",
			"scope": [
				"support.type.property-name.css"
			],
			"settings": {
				"foreground": "#e8d8ff"
			}
		},
		{
			"name": "CSS Property Value",
			"scope": [
				"meta.property-group support.constant.property-value.css",
				"meta.property-value support.constant.property-value.css",
				"meta.property-value support.constant.named-color.css",
				"meta.property-value constant"
			],
			"settings": {
				"foreground": "#ffe862ff",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Diff Deleted",
			"scope": [
				"markup.deleted"
			],
			"settings": {
				"foreground": "#ec9799ff",
				"background": "#fedcddff"
			}
		},
		{
			"name": "Diff Inserted",
			"scope": [
				"markup.inserted"
			],
			"settings": {
				"foreground": "#41a83eff",
				"background": "#9bf199ff"
			}
		}
	],
