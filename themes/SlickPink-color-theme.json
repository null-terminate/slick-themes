{
	"name": "Slick Pink",
	"type": "dark",
	"tokenColors": [
		{
			"name": "Comment",
			"scope": [
				"comment"
			],
			"settings": {
				"foreground": "#956585",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Constant",
			"scope": [
				"constant"
			],
			"settings": {
				"foreground": "#ffb452"
			}
		},
		{
			"name": "Keyword",
			"scope": [
				"keyword"
			],
			"settings": {
				"foreground": "#ff419a"
			}
		},
		{
			"name": "Entity",
			"scope": [
				"entity"
			],
			"settings": {
				"foreground": "#ff59c8"
			}
		},
		{
			"name": "Storage",
			"scope": [
				"storage"
			],
			"settings": {
				"foreground": "#ff52a8",
				"fontStyle": "bold"
			}
		},
		{
			"name": "String",
			"scope": [
				"string"
			],
			"settings": {
				"foreground": "#e8ffe5",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Support",
			"scope": [
				"support"
			],
			"settings": {
				"foreground": "#ff66e0",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Variable",
			"scope": [
				"variable"
			],
			"settings": {
				"foreground": "#88ff88",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Invalid",
			"scope": [
				"invalid"
			],
			"settings": {
				"foreground": "#ffffffff",
				"background": "#aa336a"
			}
		},
		{
			"name": "Embedded Source",
			"scope": [
				"text source"
			],
			"settings": {
				"background": "#b0b3ba14"
			}
		},
		{
			"name": "Entity inherited-class",
			"scope": [
				"entity.other.inherited-class"
			],
			"settings": {
				"foreground": "#aa5507ff",
				"fontStyle": "underline"
			}
		},
		{
			"name": "String embedded-source",
			"scope": [
				"string.quoted source"
			],
			"settings": {
				"foreground": "#9df39fff"
			}
		},
		{
			"name": "String constant",
			"scope": [
				"string constant"
			],
			"settings": {
				"foreground": "#ffe862ff"
			}
		},
		{
			"name": "String.regexp",
			"scope": [
				"string.regexp"
			],
			"settings": {
				"foreground": "#ffb454ff"
			}
		},
		{
			"name": "Support.function",
			"scope": [
				"support.function"
			],
			"settings": {
				"foreground": "#ffb454ff"
			}
		},
		{
			"name": "Support.constant",
			"scope": [
				"support.constant"
			],
			"settings": {
				"foreground": "#eb939aff"
			}
		},
		{
			"name": "Doctype/XML Processing",
			"scope": [
				"declaration.sgml.html declaration.doctype",
				"declaration.sgml.html declaration.doctype entity",
				"declaration.sgml.html declaration.doctype string",
				"declaration.xml-processing",
				"declaration.xml-processing entity",
				"declaration.xml-processing string"
			],
			"settings": {
				"foreground": "#73817dff"
			}
		},
		{
			"name": "Tags",
			"scope": [
				"declaration.tag",
				"meta.tag"
			],
			"settings": {
				"foreground": "#ff8250",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Tag Entities",
			"scope": [
				"declaration.tag.inline",
				"declaration.tag.inline entity",
				"source entity.name.tag",
				"source entity.other.attribute-name",
				"meta.tag.inline",
				"meta.tag.inline entity",
				"entity.other.bracket"
			],
			"settings": {
				"foreground": "#ff00aa",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Tag Attributes",
			"scope": [
				"declaration.tag attribute-name",
				"meta.tag entity.other.attribute-name"
			],
			"settings": {
				"foreground": "#ebe71f",
				"fontStyle": "bold"
			}
		},
		{
			"name": "CSS Class",
			"scope": [
				"meta.selector.css entity.other.attribute-name.class"
			],
			"settings": {
				"foreground": "#ff8ae2"
			}
		},
		{
			"name": "CSS Property Name",
			"scope": [
				"support.type.property-name.css"
			],
			"settings": {
				"foreground": "#ffccf0"
			}
		},
		{
			"name": "CSS Property Value",
			"scope": [
				"meta.property-group support.constant.property-value.css",
				"meta.property-value support.constant.property-value.css",
				"meta.property-value support.constant.named-color.css",
				"meta.property-value constant"
			],
			"settings": {
				"foreground": "#ffe862ff",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Diff Deleted",
			"scope": [
				"markup.deleted"
			],
			"settings": {
				"foreground": "#ec9799ff",
				"background": "#fedcddff"
			}
		},
		{
			"name": "Diff Inserted",
			"scope": [
				"markup.inserted"
			],
			"settings": {
				"foreground": "#41a83eff",
				"background": "#9bf199ff"
			}
		}
	],
	"colors": {
		// Other
		"editor.background": "#2c0d1a",
		// "editorCursor.foreground": "#ff419a",
		"editor.foreground": "#F8F8F8",
		// "editor.lineHighlightBackground": "#612d45",
		// "editor.selectionBackground": "#612d45",
		// "editorWhitespace.foreground": "#c14190",
		// Main Editor
		"activityBar.activeFocusBorder": "#ff8ae2",
		"focusBorder": "#aa0077",
		"editorCursor.foreground": "#ff4ab4",
		"editorWhitespace.foreground": "#95124f",
		"editor.lineHighlightBackground": "#0000004A",
		"editor.selectionBackground": "#ff009540",
		"editorLineNumber.foreground": "#ff4ab482",
		"editorWidget.border": "#ff00aa",
		"errorForeground": "#ff00aa",
		"diffEditor.border": "#ff00aa",
		"minimap.selectionHighlight": "#ff00aaaa",
		"minimapSlider.background": "#ff00ff4d",
		"minimapSlider.hoverBackground": "#ff00d471",
		"minimapSlider.activeBackground": "#ff00aa9d",
		// Peek View
		"peekView.border": "#332e2e",
		"peekViewEditor.background": "#410",
		"peekViewTitle.background": "#aa0077",
		"peekViewTitleLabel.foreground": "#fff",
		"peekViewTitleDescription.foreground": "#eee",
		"peekViewResult.background": "#410",
		"peekViewResult.selectionBackground": "#b50589",
		"peekViewResult.matchHighlightBackground": "#007006",
		"peekViewResult.fileForeground": "#8f8",
		// Terminal
		"terminal.ansiBrightYellow": "#f80",
		"terminal.foreground": "#fcc",
		"terminal.background": "#1d0116",
		// Terminal Panel Border
		"panel.border": "#b50589",
