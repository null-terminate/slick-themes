		"menu.background": "#330022",
		// Left Menus
		"activityBar.background": "#33002f",
		"activityBar.foreground": "#f0e0e0",
		"activityBar.inactiveForeground": "#7e5757",
		"activityBarBadge.background": "#ff00aa",
